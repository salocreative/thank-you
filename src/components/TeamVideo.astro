---
interface Props {
  presenters: string;
  videoUrl: string | null;
  placeholderText?: string | null;
}

const { presenters, videoUrl, placeholderText = 'Message coming shortly' } = Astro.props;
const sectionLabel = `A message from ${presenters}`;
const iframeTitle = `A message from ${presenters}`;
---

<div class="team-video">
  <div class="section-label">{sectionLabel}</div>
  <div class="video-wrapper">
    {videoUrl ? (
      <iframe
        src={`https://player.vimeo.com/video/${videoUrl}?badge=0&autopause=0`}
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
        title={iframeTitle}
      />
    ) : (
      <div class="video-placeholder">
        <div class="play-ring">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M6 4.5L13.5 9L6 13.5V4.5Z" fill="#A16BFF"/>
          </svg>
        </div>
        <div class="placeholder-names">{presenters}</div>
        <div class="placeholder-sub">{placeholderText}</div>
      </div>
    )}
  </div>
</div>
