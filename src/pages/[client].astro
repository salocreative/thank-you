---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import TeamPhoto from '../components/TeamPhoto.astro';
import TeamVideo from '../components/TeamVideo.astro';
import ReferralNote from '../components/ReferralNote.astro';
import ActionCards from '../components/ActionCards.astro';
import TestimonialVideo from '../components/TestimonialVideo.astro';
import UpsellBlock from '../components/UpsellBlock.astro';
import Footer from '../components/Footer.astro';
import { getClients } from '../lib/getClients';
import { hasTeamVideo, type Client } from '../data/clients';

export async function getStaticPaths() {
  const clients = await getClients();

  return Object.values(clients).map((client) => ({
    params: { client: client.slug },
    props: { client },
  }));
}

interface Props {
  client: Client;
}

const { client } = Astro.props;

const paragraphs = Array.isArray(client.personalMessage)
  ? client.personalMessage
  : [client.personalMessage];
---

<Base
  title={`Thank you, ${client.clientName} — Salo`}
  description={`A personal thank you from Salo to ${client.recipientNames}.`}
>
  <SiteHeader />
  <TeamPhoto />

  <div class="personal-message">
    <div class="eyebrow">A personal note</div>
    <h1>{client.recipientNames} — it's been<br>a real pleasure.</h1>
    <div class="message-body">
      {paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </div>

  {hasTeamVideo(client) && (
    <TeamVideo
      presenters={client.teamVideoPresenters ?? 'the Salo team'}
      videoUrl={client.teamVideoUrl}
      placeholderText={client.teamVideoPlaceholderText}
    />
  )}
  <ReferralNote />
  <ActionCards referralDescription={client.referralActionDescription} />

  <hr class="divider" />

  <TestimonialVideo />
  {client.showUpsell && (
    <UpsellBlock
      heading={client.upsellHeading}
      description={client.upsellDescription}
      buttonText={client.upsellButtonText}
    />
  )}
  <Footer />
</Base>
